* text=auto

# Shell scripts and files executed in Linux containers must always use LF,
# otherwise CRLF from a Windows checkout becomes a literal `\r` in the
# shebang (`#!/bin/bash\r`) and `exec` fails with "no such file or directory".
*.sh            text eol=lf
*.bash          text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf
deploy/**       text eol=lf

# Windows-only scripts stay CRLF.
*.ps1           text eol=crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf

# Lockfiles: keep as-written by the tool.
package-lock.json   text eol=lf
pnpm-lock.yaml      text eol=lf
yarn.lock           text eol=lf

# Images and other binary assets.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
